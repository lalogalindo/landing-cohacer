{
  "title": "Evaluación Gratuita de tu Perfil",
  "description": "Completa este formulario y recibe una evaluación personalizada de tu experiencia profesional sin costo alguno.",
  "firstNameField": {
    "name": "firstName",
    "label": "Nombre",
    "placeholder": "Tu nombre",
    "type": "text",
    "required": true
  },
  "lastNameField": {
    "name": "lastName",
    "label": "Apellidos",
    "placeholder": "Tus apellidos",
    "type": "text",
    "required": true
  },
  "emailField": {
    "name": "email",
    "label": "Correo Electrónico",
    "placeholder": "tu@email.com",
    "type": "email",
    "required": true
  },
  "phoneField": {
    "name": "phone",
    "label": "Teléfono",
    "placeholder": "+52 55 1234 5678",
    "type": "tel",
    "required": true
  },
  "ageField": {
    "name": "age",
    "label": "Edad",
    "placeholder": "Selecciona tu edad",
    "required": true,
    "options": [
      { "value": "18-24", "label": "18 a 24 años" },
      { "value": "25-34", "label": "25 a 34 años" },
      { "value": "35-44", "label": "35 a 44 años" },
      { "value": "45-54", "label": "45 a 54 años" },
      { "value": "55-plus", "label": "55 años o más" }
    ]
  },
  "educationLevelField": {
    "name": "educationLevel",
    "label": "Nivel de Estudios Actual",
    "placeholder": "Selecciona tu nivel",
    "required": true,
    "options": [
      { "value": "secundaria", "label": "Secundaria" },
      { "value": "bachillerato", "label": "Bachillerato" },
      { "value": "tecnico", "label": "Técnico" },
      { "value": "tsu", "label": "TSU" },
      { "value": "licenciatura-inconclusa", "label": "Licenciatura inconclusa" },
      { "value": "licenciatura", "label": "Licenciatura" }
    ]
  },
  "programField": {
    "name": "program",
    "label": "Programa de Interés",
    "placeholder": "Selecciona un programa",
    "required": true,
    "options": [
      { "value": "administracion", "label": "Administración" },
      { "value": "contaduria", "label": "Contaduría" },
      { "value": "ingenieria-industrial", "label": "Ingeniería Industrial" },
      { "value": "derecho", "label": "Derecho" },
      { "value": "mercadotecnia", "label": "Mercadotecnia" },
      { "value": "sistemas", "label": "Sistemas Computacionales" }
    ]
  },
  "experienceField": {
    "name": "experience",
    "label": "Años de Experiencia Profesional",
    "placeholder": "Selecciona tu experiencia",
    "required": true,
    "options": [
      { "value": "1-2", "label": "1 a 2 años" },
      { "value": "3-5", "label": "3 a 5 años" },
      { "value": "6-9", "label": "6 a 9 años" },
      { "value": "10-14", "label": "10 a 14 años" },
      { "value": "15-plus", "label": "15 años o más" }
    ]
  },
  "workAreaField": {
    "name": "workArea",
    "label": "Área de Trabajo Actual",
    "placeholder": "Ej: Administración, Contabilidad, Ingeniería, Ventas...",
    "type": "text"
  },
  "currentPositionField": {
    "name": "currentPosition",
    "label": "Puesto Actual",
    "placeholder": "Ej: Supervisor, Coordinador, Gerente, Especialista...",
    "type": "text"
  },
  "goalsField": {
    "name": "goals",
    "label": "¿Cuáles son tus objetivos profesionales?",
    "placeholder": "Cuéntanos qué esperas lograr con tu título profesional...",
    "rows": 5
  },
  "timelineField": {
    "name": "timeline",
    "label": "¿En qué tiempo te gustaría obtener tu título?",
    "placeholder": "Selecciona un plazo",
    "required": true,
    "options": [
      { "value": "inmediato", "label": "Lo antes posible" },
      { "value": "1-3-meses", "label": "1 a 3 meses" },
      { "value": "3-6-meses", "label": "3 a 6 meses" },
      { "value": "6-12-meses", "label": "6 a 12 meses" },
      { "value": "solo-informacion", "label": "Solo estoy evaluando opciones" }
    ]
  },
  "privacyConsentField": {
    "name": "privacyConsent",
    "required": true,
    "labelPrefix": "Acepto el",
    "linkLabel": "aviso de privacidad",
    "linkHref": "/aviso-de-privacidad",
    "labelSuffix": "y autorizo el uso de mis datos para fines educativos y de contacto."
  },
  "marketingConsentField": {
    "name": "marketingConsent",
    "label": "Deseo recibir información sobre promociones y nuevos programas educativos."
  },
  "submitLabel": "Obtener Evaluación Gratuita",
  "disclaimer": "* Campos obligatorios. La evaluación es completamente gratuita y sin compromiso."
}