      "placeholder": "Ej. Juan Pérez"
    },
    {
      "key": "email",
      "label": "Email",
      "required": true,
      "placeholder": "correo@ejemplo.com"
    },
    {
      "key": "phone",
      "label": "Teléfono",
      "required": true,
      "placeholder": "+52 ..."
