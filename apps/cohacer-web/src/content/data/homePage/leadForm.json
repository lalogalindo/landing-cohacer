    {
      "key": "program",
      "label": "Área de experiencia",
      "required": true,
      "options": [
        "Administración",
        "Recursos Humanos",
        "Producción",
        "Contabilidad",
        "Educación",
        "Salud",
        "Otra"
      ]
    },
    {
      "key": "source",
      "label": "Nivel de interés",
      "required": true,
      "options": [
        "Solo estoy explorando",
        "Quiero información pronto",
        "Quiero iniciar ya"
      ]
